{
  "name": "ramesh-saini-mvp",
  "version": "7.1.0-mvp",
  "description": "Ramesh Saini v7.1 — Ironclad MVP Desktop Application",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "build:renderer": "mkdir -p renderer/dist && cp renderer/index.html renderer/dist/",
    "build": "npm run build:renderer && electron-builder --win",
    "build:linux": "npm run build:renderer && electron-builder --linux",
    "build:all": "npm run build:renderer && electron-builder --win --linux",
    "test": "node test/smoke-test.js",
    "dev": "NODE_ENV=development electron ."
  },
  "build": {
    "appId": "com.rameshsaini.mvp",
    "productName": "Ramesh Saini MVP",
    "copyright": "Copyright © 2026 Ramesh Saini",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "renderer/dist/**/*",
      "backend/**/*.py",
      "!backend/__pycache__/**",
      "!**/*.pyc"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": ["**/*.py"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "unicode": true
    },
    "asar": false,
    "asarUnpack": ["backend/**"]
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.0"
  }
}
